 146:Core/Src/freertos.c **** void vApplicationIdleHook( void )
ARM GAS  /tmp/ccFu8X3s.s 			page 4


 147:Core/Src/freertos.c **** {
 148:Core/Src/freertos.c ****    /* vApplicationIdleHook() will only be called if configUSE_IDLE_HOOK is set
 149:Core/Src/freertos.c ****    to 1 in FreeRTOSConfig.h. It will be called on each iteration of the idle
 150:Core/Src/freertos.c ****    task. It is essential that code added to this hook function never attempts
 151:Core/Src/freertos.c ****    to block in any way (for example, call xQueueReceive() with a block time
 152:Core/Src/freertos.c ****    specified, or call vTaskDelay()). If the application makes use of the
 153:Core/Src/freertos.c ****    vTaskDelete() API function (as this demo application does) then it is also
 154:Core/Src/freertos.c ****    important that vApplicationIdleHook() is permitted to return to its calling
 155:Core/Src/freertos.c ****    function, because it is the responsibility of the idle task to clean up
 156:Core/Src/freertos.c ****    memory allocated by the kernel to any task that has since been deleted. */
 157:Core/Src/freertos.c **** }
 158:Core/Src/freertos.c **** /* USER CODE END 2 */
 159:Core/Src/freertos.c **** 
 160:Core/Src/freertos.c **** /* USER CODE BEGIN 3 */
 161:Core/Src/freertos.c **** void vApplicationTickHook( void )
 162:Core/Src/freertos.c **** {
 163:Core/Src/freertos.c ****    /* This function will be called by each tick interrupt if
 164:Core/Src/freertos.c ****    configUSE_TICK_HOOK is set to 1 in FreeRTOSConfig.h. User code can be
 165:Core/Src/freertos.c ****    added here, but the tick hook is called from an interrupt context, so
 166:Core/Src/freertos.c ****    code must not attempt to block, and only the interrupt safe FreeRTOS API
 167:Core/Src/freertos.c ****    functions can be used (those that end in FromISR()). */
 168:Core/Src/freertos.c **** }
 169:Core/Src/freertos.c **** /* USER CODE END 3 */
 170:Core/Src/freertos.c **** 
 171:Core/Src/freertos.c **** /* USER CODE BEGIN 4 */
 172:Core/Src/freertos.c **** void vApplicationStackOverflowHook(xTaskHandle xTask, signed char *pcTaskName)
 173:Core/Src/freertos.c **** {
 174:Core/Src/freertos.c ****    /* Run time stack overflow checking is performed if
 175:Core/Src/freertos.c ****    configCHECK_FOR_STACK_OVERFLOW is defined to 1 or 2. This hook function is
 176:Core/Src/freertos.c ****    called if a stack overflow is detected. */
 177:Core/Src/freertos.c ****    for(;;){
 178:Core/Src/freertos.c ****       HAL_GPIO_TogglePin(GPIOF, GPIO_PIN_5); // 发生栈溢出时，PC13 翻转，方便调试
 179:Core/Src/freertos.c ****    }
 180:Core/Src/freertos.c ****    
 181:Core/Src/freertos.c **** }
 182:Core/Src/freertos.c **** /* USER CODE END 4 */
 183:Core/Src/freertos.c **** 
 184:Core/Src/freertos.c **** /* USER CODE BEGIN 5 */
 185:Core/Src/freertos.c **** void vApplicationMallocFailedHook(void)
 186:Core/Src/freertos.c **** {
 187:Core/Src/freertos.c ****    /* vApplicationMallocFailedHook() will only be called if
 188:Core/Src/freertos.c ****    configUSE_MALLOC_FAILED_HOOK is set to 1 in FreeRTOSConfig.h. It is a hook
 189:Core/Src/freertos.c ****    function that will get called if a call to pvPortMalloc() fails.
 190:Core/Src/freertos.c ****    pvPortMalloc() is called internally by the kernel whenever a task, queue,
 191:Core/Src/freertos.c ****    timer or semaphore is created. It is also called by various parts of the
 192:Core/Src/freertos.c ****    demo application. If heap_1.c or heap_2.c are used, then the size of the
 193:Core/Src/freertos.c ****    heap available to pvPortMalloc() is defined by configTOTAL_HEAP_SIZE in
 194:Core/Src/freertos.c ****    FreeRTOSConfig.h, and the xPortGetFreeHeapSize() API function can be used
 195:Core/Src/freertos.c ****    to query the size of free heap space that remains (although it does not
 196:Core/Src/freertos.c ****    provide information on how the remaining heap might be fragmented). */
 197:Core/Src/freertos.c **** }
 198:Core/Src/freertos.c **** /* USER CODE END 5 */
