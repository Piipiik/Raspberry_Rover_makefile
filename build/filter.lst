   1:Control/FILTER/filter.c **** #include "filter.h"
   2:Control/FILTER/filter.c **** #include <math.h> // 必须包含数学库
   3:Control/FILTER/filter.c **** #include "mpu6050.h"
   4:Control/FILTER/filter.c **** #include <main.h>
   5:Control/FILTER/filter.c **** 
   6:Control/FILTER/filter.c **** 
   7:Control/FILTER/filter.c **** // 互补滤波参数
   8:Control/FILTER/filter.c **** #define K_FILTER  0.98f   // 权重系数 (0.95 ~ 0.98)
   9:Control/FILTER/filter.c **** #define DT        0.005f  // 采样时间 (秒)，假设你每 10ms 调用一次
  10:Control/FILTER/filter.c **** 
  11:Control/FILTER/filter.c **** // 全局变量，用来保存当前的最终角度
  12:Control/FILTER/filter.c **** // 必须是全局的，因为它是“积分”的，要记得上一次的值
  13:Control/FILTER/filter.c **** float Pitch_Angle = 0; 
  14:Control/FILTER/filter.c **** 
  15:Control/FILTER/filter.c **** // 我测着是-39
  16:Control/FILTER/filter.c **** float Gyro_X_Offset = -39; // 全局变量，存偏差值
  17:Control/FILTER/filter.c **** float Gyro_Z_Offset = -29;
  18:Control/FILTER/filter.c **** 
  19:Control/FILTER/filter.c **** void Filter_Init(void)
  20:Control/FILTER/filter.c **** {
  21:Control/FILTER/filter.c ****     int16_t ax, ay, az, gx, gy, gz;
  22:Control/FILTER/filter.c **** 
  23:Control/FILTER/filter.c ****     // 给用户一个心理准备时间，也等待传感器内部稳定
  24:Control/FILTER/filter.c ****     HAL_Delay(500); 
  25:Control/FILTER/filter.c **** 
  26:Control/FILTER/filter.c ****     // === 核心：快速收敛循环 ===
  27:Control/FILTER/filter.c ****     // 循环 100 次，每次间隔 5ms (模拟真实的控制周期)
  28:Control/FILTER/filter.c ****     // 目的：利用互补滤波的特性，让 Pitch_Angle 快速追上真实的重力角度
  29:Control/FILTER/filter.c ****     for(int i = 0; i < 100; i++)
  30:Control/FILTER/filter.c ****     {
ARM GAS  /tmp/ccvGljQ4.s 			page 2


  31:Control/FILTER/filter.c ****         // 1. 获取数据
  32:Control/FILTER/filter.c ****         MPU6050_GetData(&ax, &ay, &az, &gx, &gy, &gz);
  33:Control/FILTER/filter.c **** 
  34:Control/FILTER/filter.c ****         // 2. 跑一遍姿态解算
  35:Control/FILTER/filter.c ****         // 【重要】：这里一定要填你刚才测试通过的、正确的轴！！！
  36:Control/FILTER/filter.c ****         // 如果你测出来是 ax 和 gx，就填 ax, az, gx
  37:Control/FILTER/filter.c ****         // 如果还是 ay 和 gy，就填 ay, az, gy
  38:Control/FILTER/filter.c ****         MPU6050_Update_Posture(ay, az, gx); 
  39:Control/FILTER/filter.c ****         
  40:Control/FILTER/filter.c ****         // 3. 延时 5ms，模拟真实采样率
  41:Control/FILTER/filter.c ****         HAL_Delay(5);
  42:Control/FILTER/filter.c ****     }
  43:Control/FILTER/filter.c ****     
  44:Control/FILTER/filter.c ****     // 循环结束后，Pitch_Angle 已经等于当前真实的物理角度了。
  45:Control/FILTER/filter.c ****     // 此时再启动电机，如果角度 > 45，电机绝对不会转。
  46:Control/FILTER/filter.c **** }
  47:Control/FILTER/filter.c **** 
