 103:Hardware/OLED/oled.c **** // е…ЁеұҸеҲ·ж–°
 104:Hardware/OLED/oled.c **** void OLED_Refresh(void) {
 105:Hardware/OLED/oled.c ****     uint8_t *pRAM = (uint8_t *)OLED_GRAM; 
 106:Hardware/OLED/oled.c ****     uint16_t i;
 107:Hardware/OLED/oled.c **** 
 108:Hardware/OLED/oled.c ****     // 1. и®ҫзҪ®еҶҷе…ҘзӘ—еҸЈдёәе…ЁеұҸ
 109:Hardware/OLED/oled.c ****     OLED_Write_Cmd(0x21); OLED_Write_Cmd(0x00); OLED_Write_Cmd(0x7F);
 110:Hardware/OLED/oled.c ****     OLED_Write_Cmd(0x22); OLED_Write_Cmd(0x00); OLED_Write_Cmd(0x07);
 111:Hardware/OLED/oled.c **** 
 112:Hardware/OLED/oled.c ****     // 2. иҝһз»ӯеҶҷе…Ҙ1024дёӘеӯ—иҠӮзҡ„ж•°жҚ®
 113:Hardware/OLED/oled.c ****     MyI2C_Start(g_oled_i2c);
 114:Hardware/OLED/oled.c ****     MyI2C_SendByte(g_oled_i2c, g_oled_addr); MyI2C_WaitAck(g_oled_i2c);
 115:Hardware/OLED/oled.c ****     MyI2C_SendByte(g_oled_i2c, 0x40);      MyI2C_WaitAck(g_oled_i2c); // ж•°жҚ®жЁЎејҸ
 116:Hardware/OLED/oled.c **** 
 117:Hardware/OLED/oled.c ****     for (i = 0; i < 1024; i++) {
 118:Hardware/OLED/oled.c ****         MyI2C_SendByte(g_oled_i2c, pRAM[i]);
 119:Hardware/OLED/oled.c ****         MyI2C_WaitAck(g_oled_i2c);
 120:Hardware/OLED/oled.c ****     }
 121:Hardware/OLED/oled.c ****     MyI2C_Stop(g_oled_i2c);
 122:Hardware/OLED/oled.c **** }
 123:Hardware/OLED/oled.c **** 
 124:Hardware/OLED/oled.c **** // еұҖйғЁеҲ·ж–° (жҸҗй«ҳеё§зҺҮзҡ„е…ій”®)
 125:Hardware/OLED/oled.c **** void OLED_Refresh_Part(uint8_t x, uint8_t y, uint8_t w, uint8_t h) {
 126:Hardware/OLED/oled.c ****     uint8_t i, n;
 127:Hardware/OLED/oled.c **** 
 128:Hardware/OLED/oled.c ****     // 1. и®ҫзҪ®йҷҗеҲ¶зӘ—еҸЈ (еҲ©з”ЁзЎ¬д»¶зү№жҖ§иҮӘеҠЁжҚўиЎҢ)
 129:Hardware/OLED/oled.c ****     OLED_Write_Cmd(0x21); OLED_Write_Cmd(x); OLED_Write_Cmd(x + w - 1);
 130:Hardware/OLED/oled.c ****     OLED_Write_Cmd(0x22); OLED_Write_Cmd(y); OLED_Write_Cmd(y + h - 1);
 131:Hardware/OLED/oled.c **** 
 132:Hardware/OLED/oled.c ****     // 2. еҶҷе…ҘзӘ—еҸЈеҶ…зҡ„ж•°жҚ®
 133:Hardware/OLED/oled.c ****     MyI2C_Start(g_oled_i2c);
 134:Hardware/OLED/oled.c ****     MyI2C_SendByte(g_oled_i2c, g_oled_addr); MyI2C_WaitAck(g_oled_i2c);
 135:Hardware/OLED/oled.c ****     MyI2C_SendByte(g_oled_i2c, 0x40);      MyI2C_WaitAck(g_oled_i2c);
 136:Hardware/OLED/oled.c **** 
 137:Hardware/OLED/oled.c ****     for(i = 0; i < h; i++) {       // йҒҚеҺҶйЎө
 138:Hardware/OLED/oled.c ****         for(n = 0; n < w; n++) {   // йҒҚеҺҶеҲ—
 139:Hardware/OLED/oled.c ****             MyI2C_SendByte(g_oled_i2c, OLED_GRAM[y + i][x + n]);
 140:Hardware/OLED/oled.c ****             MyI2C_WaitAck(g_oled_i2c);
 141:Hardware/OLED/oled.c ****         }
 142:Hardware/OLED/oled.c ****     }
 143:Hardware/OLED/oled.c ****     MyI2C_Stop(g_oled_i2c);
 144:Hardware/OLED/oled.c **** }
 145:Hardware/OLED/oled.c **** 
 146:Hardware/OLED/oled.c **** void OLED_Clear(uint8_t m) {
 147:Hardware/OLED/oled.c ****     // дҪҝз”Ёж ҮеҮҶеә“ memset жһҒйҖҹжё…йӣ¶пјҢжҜ” for еҫӘзҺҜеҝ«
 148:Hardware/OLED/oled.c ****     if (m) {
