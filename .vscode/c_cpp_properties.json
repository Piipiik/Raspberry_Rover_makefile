                "${workspaceFolder}/Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM3",
                "${workspaceFolder}/BSP/Inc",
                "${workspaceFolder}/Control/FILTER",
                "${workspaceFolder}/Control/kinematics",
                "${workspaceFolder}/Control/PID",
                "${workspaceFolder}/Hardware/MPU6050",
                "${workspaceFolder}/Hardware/OLED",
                "${workspaceFolder}/Hardware/Motor",
                "${workspaceFolder}/Hardware/Bluetooth",
                "${workspaceFolder}/App",
